{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Kb2uka/openhpsdr-zeus/main/docs/plugins/registry.schema.json",
  "title": "Openhpsdr-Zeus plugin registry",
  "description": "Schema for registry.json hosted by the Kb2uka/openhpsdr-zeus-plugins repo.",
  "type": "object",
  "required": ["schemaVersion", "generated", "plugins"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "generated": { "type": "string", "format": "date-time" },
    "plugins": {
      "type": "array",
      "items": { "$ref": "#/$defs/pluginEntry" }
    }
  },
  "$defs": {
    "pluginEntry": {
      "type": "object",
      "required": ["id", "name", "versions"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "author": { "type": "string" },
        "license": { "type": "string" },
        "homepage": { "type": "string", "format": "uri" },
        "categories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "verified": { "type": "boolean" },
        "versions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/pluginVersion" }
        }
      }
    },
    "pluginVersion": {
      "type": "object",
      "required": ["version", "sdkAbi", "sdkMinVersion", "platforms", "downloadUrl", "sha256"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+([+-][0-9A-Za-z.-]+)?$"
        },
        "sdkAbi": { "type": "integer", "minimum": 1 },
        "sdkMinVersion": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "platforms": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["any", "linux-x64", "linux-arm64", "win-x64", "osx-x64", "osx-arm64"]
          }
        },
        "downloadUrl": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        }
      }
    }
  }
}
